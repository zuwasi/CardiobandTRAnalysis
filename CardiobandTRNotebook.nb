Notebook[{
Cell["Cardioband TR EFS 1-Year Outcomes", "Title"],
Cell["Aggregate Wolfram reproduction of Gray WA et al., JACC: Cardiovascular Interventions 2022;15(19):1921-1932.", "Subtitle"],
Cell["Scope", "Section"],
Cell["This notebook loads the reusable package, displays the claim ledger, recomputes aggregate percentages and reductions, and generates figures. Patient-level data are not available, so exact Kaplan-Meier and Wilcoxon reconstructions are intentionally not claimed.", "Text"],
Cell["SetDirectory[NotebookDirectory[]];\nGet[FileNameJoin[{NotebookDirectory[], \"src\", \"CardiobandTRModel.wl\"}]];", "Input"],
Cell["Paper metadata", "Section"],
Cell["CardiobandTRModel`PaperMetadata[] // Dataset", "Input"],
Cell["Claim recomputation", "Section"],
Cell["CardiobandTRModel`RecomputeClaims[] // Dataset", "Input"],
Cell["Validation suite", "Section"],
Cell["validation = CardiobandTRModel`RunValidationSuite[];\nDataset[validation]", "Input"],
Cell["Annular diameter trajectory", "Section"],
Cell["ann = CardiobandTRModel`AnnularDiameterData[];\nListLinePlot[ann[[All, \"MeanCm\"]], DataRange -> {1, Length[ann]}, PlotMarkers -> Automatic, Frame -> True, FrameLabel -> {\"Visit\", \"Mean annular diameter (cm)\"}, PlotLabel -> \"Tricuspid annular diameter reduction\", Epilog -> MapIndexed[Text[#1[\"Timepoint\"], {First[#2], #1[\"MeanCm\"] + 0.08}] &, ann], ImageSize -> 800]", "Input"],
Cell["TR severity at 1 year", "Section"],
Cell["tr = CardiobandTRModel`TRGradeOutcomeData[];\nBarChart[Values[tr[\"OneYearSeverityPercent\"]], ChartLabels -> Placed[Keys[tr[\"OneYearSeverityPercent\"]], Below], Frame -> True, FrameLabel -> {\"TR grade\", \"Patients (%)\"}, PlotLabel -> \"1-year TR severity distribution\", ImageSize -> 800]", "Input"],
Cell["KCCQ quality-of-life change", "Section"],
Cell["fun = CardiobandTRModel`FunctionalOutcomeData[];\nBarChart[{fun[\"KCCQ\", \"BaselineMean\"], fun[\"KCCQ\", \"OneYearMean\"]}, ChartLabels -> {\"Baseline\", \"1 Year\"}, Frame -> True, FrameLabel -> {\"Visit\", \"KCCQ score\"}, PlotLabel -> \"KCCQ improvement\", ImageSize -> 650]", "Input"],
Cell["Major adverse events", "Section"],
Cell["mae = CardiobandTRModel`MajorAdverseEventData[];\nDataset[mae]", "Input"],
Cell["Export artifacts", "Section"],
Cell["CardiobandTRModel`ExportProjectArtifacts[FileNameJoin[{NotebookDirectory[], \"exports\"}]];", "Input"],
Cell["Key findings", "Section"],
Cell["StringRiffle[{\"KEY FINDINGS\", \"Paired annular diameter reduction: \" <> ToString[CardiobandTRModel`RecomputeClaims[][\"PairedAnnularPercentReduction\"]] <> \"%.\", \"TR <= moderate at 1 year: \" <> ToString[CardiobandTRModel`RecomputeClaims[][\"TRAtMostModeratePercent\"]] <> \"%.\", \"KCCQ change from rounded means: \" <> ToString[CardiobandTRModel`RecomputeClaims[][\"KCCQChangeFromMeans\"]] <> \" points.\", \"6MWD aggregate t-test P: \" <> ToString[NumberForm[CardiobandTRModel`RecomputeClaims[][\"SixMinuteWalkTP\"], {4, 4}]]}, \"\\n\"]", "Input"]
}]
