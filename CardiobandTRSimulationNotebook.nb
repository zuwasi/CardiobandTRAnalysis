 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Rows\"\>", "\[Rule]", "37"}], ",", 
   RowBox[{"\<\"SyntheticWarning\"\>", 
    "\[Rule]", "\<\"These rows are simulated for demonstration only and are \
not real Cardioband patient-level trial data.\"\>"}], ",", 
