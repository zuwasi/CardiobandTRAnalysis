Cell[CellGroupData[{

Cell["Interactive what-if: scale KCCQ treatment effect", "Section",ExpressionUUID->"7a3e9d10-b222-354d-9d2a-f13d567e5b16"],

Cell[CellGroupData[{

Cell["\<\
Manipulate[Module[{localData, localFollow, adjusted}, localData = \
CardiobandTRModel`SimulatePatientDataset[42]; localFollow = Select[localData, \
TrueQ[#HasOneYearEcho] &]; adjusted = Map[<|#, \"AdjustedKCCQOneYear\" -> \
Min[100, #[\"KCCQBaseline\"] + effectScale (#[\"KCCQOneYear\"] - \
#[\"KCCQBaseline\"])]|> &, localFollow]; ListPlot[adjusted[[All, \
{\"KCCQBaseline\", \"AdjustedKCCQOneYear\"}]], Frame -> True, FrameLabel -> {\
\"Baseline KCCQ\", \"Adjusted 1-year KCCQ\"}, PlotRange -> {{0, 100}, {0, \
100}}, PlotLabel -> \"What-if KCCQ response scale = \" <> \
ToString[effectScale], ImageSize -> 700]], {{effectScale, 1.0, \"effect scale\
\"}, 0.25, 1.75, 0.25}]\
\>", "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"b59e0dda-e27c-734d-ba0b-5386d8c51ef2"],

Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`effectScale$$ = 1., Typeset`show$$ = True, 
    Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
    Typeset`animator$$, Typeset`animvar$$ = 1, Typeset`name$$ = 
    "\"untitled\"", Typeset`specs$$ = {{{
       Hold[$CellContext`effectScale$$], 1., "effect scale"}, 0.25, 1.75, 
      0.25, ControlType -> Manipulator}}, Typeset`size$$ = {
    525., {168.8192618922726, 173.1182120875851}}, Typeset`update$$ = 0, 
    Typeset`initDone$$, Typeset`skipInitDone$$ = True, 
    Typeset`keyframeActionsQ$$ = False, Typeset`keyframeList$$ = {}}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, "Variables" :> {$CellContext`effectScale$$ = 1.}, 
      "ControllerVariables" :> {}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$, Typeset`keyframeActionsQ$$, 
        Typeset`keyframeList$$}, "Body" :> 
      Module[{$CellContext`localData$, $CellContext`localFollow$, \
$CellContext`adjusted$}, $CellContext`localData$ = 
         CardiobandTRModel`SimulatePatientDataset[
          42]; $CellContext`localFollow$ = 
         Select[$CellContext`localData$, TrueQ[
            Slot["HasOneYearEcho"]]& ]; $CellContext`adjusted$ = 
         Map[<|#, "AdjustedKCCQOneYear" -> 
            Min[100, #[
               "KCCQBaseline"] + $CellContext`effectScale$$ (#[
                 "KCCQOneYear"] - #[
                "KCCQBaseline"])]|>& , $CellContext`localFollow$]; ListPlot[
          
          Part[$CellContext`adjusted$, All, {
           "KCCQBaseline", "AdjustedKCCQOneYear"}], Frame -> True, 
          FrameLabel -> {"Baseline KCCQ", "Adjusted 1-year KCCQ"}, 
          PlotRange -> {{0, 100}, {0, 100}}, PlotLabel -> 
          "What-if KCCQ response scale = " <> 
